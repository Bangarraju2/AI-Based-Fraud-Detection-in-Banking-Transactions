# ============================================
# AI-Based Fraud Detection - Environment Config
# ============================================

# Database
DATABASE_URL=postgresql+asyncpg://fraud_user:fraud_pass_2024@localhost:5432/fraud_detection_db
DATABASE_URL_SYNC=postgresql://fraud_user:fraud_pass_2024@localhost:5432/fraud_detection_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-2024
JWT_REFRESH_SECRET_KEY=your-refresh-secret-key-change-in-production-2024
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ML Service
ML_SERVICE_URL=http://ml_service:8001

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# App
APP_NAME=FraudShield AI
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# PostgreSQL (for Docker)
POSTGRES_USER=fraud_user
POSTGRES_PASSWORD=fraud_pass_2024
POSTGRES_DB=fraud_detection_db
